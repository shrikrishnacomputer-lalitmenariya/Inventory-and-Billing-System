generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               Int                @id @default(autoincrement())
  name             String             
  username         String             @unique 
  passwordHash     String             @map("password_hash") 
  role             String             
  isActive         Boolean            @default(true) @map("is_active")
  createdAt        DateTime           @default(now()) @map("created_at")
  stockInRecords   StockInRecord[]
  bills            Bill[]

  @@map("users")
}

model Category {
  id               Int                @id @default(autoincrement())
  name             String             
  parentCategoryId Int?               @map("parent_category_id")
  isActive         Boolean            @default(true) @map("is_active")
  parentCategory   Category?          @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  subCategories    Category[]         @relation("CategoryHierarchy")
  products         Product[]

  @@map("categories")
}

model Product {
  id                  Int                @id @default(autoincrement())
  categoryId          Int                @map("category_id")
  name                String             
  brand               String?            
  productType         String             @map("product_type") 
  costPrice           Decimal            @map("cost_price") 
  sellingPrice        Decimal            @map("selling_price") 
  quantityInStock     Int                @default(0) @map("quantity_in_stock")
  lowStockThreshold   Int                @default(5) @map("low_stock_threshold")
  imageUrl            String?            @map("image_url")
  isActive            Boolean            @default(true) @map("is_active")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  category            Category           @relation(fields: [categoryId], references: [id])
  units               ProductUnit[]
  stockInRecords      StockInRecord[]
  billItems           BillItem[]

  @@map("products")
}

model ProductUnit {
  id            Int         @id @default(autoincrement())
  productId     Int         @map("product_id")
  imeiNumber    String      @unique @map("imei_number") 
  status        String      
  costPrice     Decimal     @map("cost_price") 
  addedAt       DateTime    @default(now()) @map("added_at")
  soldAt        DateTime?   @map("sold_at")

  product       Product     @relation(fields: [productId], references: [id])
  billItems     BillItem[]

  @@map("product_units")
}

model StockInRecord {
  id             Int       @id @default(autoincrement())
  productId      Int       @map("product_id")
  quantityAdded  Int       @map("quantity_added")
  costPrice      Decimal   @map("cost_price") 
  addedByUserId  Int       @map("added_by_user_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  product        Product   @relation(fields: [productId], references: [id])
  user           User      @relation(fields: [addedByUserId], references: [id])

  @@map("stock_in_records")
}

model Customer {
  id      Int      @id @default(autoincrement())
  name    String?  
  phone   String?  
  bills   Bill[]

  @@map("customers")
}

model Bill {
  id               Int         @id @default(autoincrement())
  billNumber       String      @unique @map("bill_number") 
  customerId       Int?        @map("customer_id")
  createdByUserId  Int         @map("created_by_user_id")
  subtotal         Decimal     
  discount         Decimal     @default(0) 
  totalAmount      Decimal     @map("total_amount") 
  paymentMode      String      @map("payment_mode") 
  status           String      
  createdAt        DateTime    @default(now()) @map("created_at")

  customer         Customer?   @relation(fields: [customerId], references: [id])
  user             User        @relation(fields: [createdByUserId], references: [id])
  billItems        BillItem[]

  @@map("bills")
}

model BillItem {
  id              Int          @id @default(autoincrement())
  billId          Int          @map("bill_id")
  productId       Int          @map("product_id")
  productUnitId   Int?         @map("product_unit_id")
  quantity        Int
  unitPrice       Decimal      @map("unit_price") 
  lineTotal       Decimal      @map("line_total") 

  bill            Bill         @relation(fields: [billId], references: [id])
  product         Product      @relation(fields: [productId], references: [id])
  productUnit     ProductUnit? @relation(fields: [productUnitId], references: [id])

  @@map("bill_items")
}
